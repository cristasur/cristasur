# ========================================
# CRISTASUR - Variables de entorno
# Copia este archivo como `.env.local` y rellena los valores reales
# NUNCA subas .env.local al repositorio
# ========================================

# Conexión a MongoDB
# Local:   mongodb://127.0.0.1:27017/cristasur
# Atlas:   mongodb+srv://usuario:password@cluster.mongodb.net/cristasur
MONGODB_URI=mongodb://127.0.0.1:27017/cristasur

# Secreto para firmar los JWT (usa una cadena larga y aleatoria en producción)
# Puedes generar uno con:  openssl rand -base64 48
JWT_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio-minimo-32-caracteres

# Credenciales iniciales del usuario administrador (se crean al ejecutar `npm run seed`)
# IMPORTANTE: usá una contraseña FUERTE y única — esto crea tu cuenta admin en Mongo.
# Después del primer seed, cambiala desde el panel y rotá esta variable en producción.
SEED_ADMIN_EMAIL=admin@cristasur.com
SEED_ADMIN_PASSWORD=

# Emails de administradores para notificaciones (separados por coma)
# Ejemplo: ADMIN_NOTIFY_EMAILS=tuEmail@gmail.com,otroEmail@gmail.com
ADMIN_NOTIFY_EMAILS=

# URL pública del sitio (usada en links absolutos y CSRF)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — servicio de correo transaccional (recuperación de contraseña, verificación)
# Obtén tu API key en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel Blob — token de lectura/escritura para subir imágenes
# En Vercel: Settings > Storage > Blob > tu store > Read-Write Token
# Solo necesario para los scripts locales (add-blog, add-product).
# En producción Vercel lo inyecta automáticamente.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth — Login con Google
# Obtén las credenciales en: https://console.cloud.google.com/apis/credentials
# 1. Crea un proyecto > Credenciales > Crear credenciales > ID de cliente OAuth 2.0
# 2. Tipo de aplicación: "Aplicación web"
# 3. URI de redireccionamiento autorizado: https://TU_DOMINIO/api/auth/google/callback
#    (en local: http://localhost:3000/api/auth/google/callback)
# ⚠️  OBLIGATORIO para que el botón "Continuar con Google" funcione
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cron Secret — protege el endpoint de carrito abandonado
# Debe coincidir con el header Authorization que Vercel Cron envía.
# Genera un valor aleatorio con: openssl rand -base64 32
# En Vercel: Settings > Environment Variables > añadir CRON_SECRET
# También debes tener la entrada "crons" en vercel.json (ya incluida).
# ⚠️  Si no se define, el cron de carrito abandonado no tendrá protección
CRON_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio
