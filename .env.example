# ========================================
# CRISTASUR - Variables de entorno
# Copia este archivo como `.env.local` y rellena los valores reales
# NUNCA subas .env.local al repositorio
# ========================================

# Conexión a MongoDB
# Local:   mongodb://127.0.0.1:27017/cristasur
# Atlas:   mongodb+srv://usuario:password@cluster.mongodb.net/cristasur
MONGODB_URI=mongodb://127.0.0.1:27017/cristasur

# Secreto para firmar los JWT (usa una cadena larga y aleatoria en producción)
# Puedes generar uno con:  openssl rand -base64 48
JWT_SECRET=cambia-este-secreto-por-uno-largo-y-aleatorio-minimo-32-caracteres

# Credenciales iniciales del usuario administrador (se crean al ejecutar `npm run seed`)
SEED_ADMIN_EMAIL=admin@cristasur.mx
SEED_ADMIN_PASSWORD=pon-aqui-una-contrasena-segura-minimo-12-caracteres

# Emails de administradores para notificaciones (separados por coma)
# Ejemplo: ADMIN_NOTIFY_EMAILS=tuEmail@gmail.com,otroEmail@gmail.com
ADMIN_NOTIFY_EMAILS=

# URL pública del sitio (usada en links absolutos y CSRF)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — servicio de correo transaccional (recuperación de contraseña, verificación)
# Obtén tu API key en https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel Blob — token de lectura/escritura para subir imágenes
# En Vercel: Settings > Storage > Blob > tu store > Read-Write Token
# Solo necesario para los scripts locales (add-blog, add-product).
# En producción Vercel lo inyecta automáticamente.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
